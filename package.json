{
  "name": "veil-protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Veil Protocol: Neon City — a cyberpunk confidential social-deduction game. Hybrid architecture: Java (authoritative real-time server) + React (render-only client) + Ollama (NPC dialogue) + Midnight (confidential referee).",
  "workspaces": [
    "frontend",
    "midnight"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "build:frontend": "npm --workspace frontend run build",
    "demo:midnight": "npm --workspace @veil/midnight run demo",
    "dev:backend": "mvn -f backend/pom.xml spring-boot:run",
    "build:backend": "mvn -f backend/pom.xml -DskipTests package",
    "relayer": "npm --workspace @veil/midnight run relayer",
    "test:backend": "mvn -f backend/pom.xml test",
    "test:e2e": "node tests/e2e/room-flow.mjs"
  }
}
